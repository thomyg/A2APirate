# =============================================================================
# A2A Learning Sample — Environment Variables
# =============================================================================

# For the SpecialistAgent (LLM backend)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Optional: Custom endpoint (e.g. GitHub Models)
# OPENAI_BASE_URL=https://models.github.ai/inference

# For the OrchestratorAgent
SPECIALIST_BASE_URL=http://localhost:5100

# Alternative: GitHub Models (no Azure account required)
# GITHUB_TOKEN=ghp_...
# OPENAI_BASE_URL=https://models.github.ai/inference
# OPENAI_API_KEY=ghp_...   (Use GitHub token as API key)
