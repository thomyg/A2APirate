# =============================================================================
# A2A Learning Sample — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Provider (used by PirateSpecialist and AI routing) -----------------

# Option A: OpenAI directly
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Option B: GitHub Models (free, no Azure account required)
OPENAI_API_KEY=your-github-token-here
OPENAI_BASE_URL=https://models.github.ai/inference

# --- A2A Endpoints ----------------------------------------------------------

# Where the SpecialistAgent is running
SPECIALIST_BASE_URL=http://localhost:5100

# --- Orchestrator Routing ---------------------------------------------------

# How the orchestrator picks which agent handles a message.
#   keyword  = rule-based routing using agent skills/tags (no AI, no API key needed)
#   ai       = LLM classifies user intent and picks the best agent
# Default: keyword
ROUTING_MODE=keyword
