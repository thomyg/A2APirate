{
  "$schema": "https://demotime.show/demo-time.schema.json",
  "title": "Demo 3: Streaming Token by Token",
  "description": "Deep-dive into SSE streaming — see how A2A delivers responses event by event.",
  "version": 3,
  "scenes": [
    {
      "title": "Introduction",
